            backgroundBlurView.leadingAnchor.constraint(equalTo: backgroundBlurContainer.leadingAnchor),
            backgroundBlurView.trailingAnchor.constraint(equalTo: backgroundBlurContainer.trailingAnchor),
            backgroundBlurView.bottomAnchor.constraint(equalTo: backgroundBlurContainer.bottomAnchor),
            
            // Color overlay fills container
            colorOverlayView.topAnchor.constraint(equalTo: backgroundBlurContainer.topAnchor),
            colorOverlayView.leadingAnchor.constraint(equalTo: backgroundBlurContainer.leadingAnchor),
