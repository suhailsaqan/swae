            titleLabel.leadingAnchor.constraint(equalTo: contentView.leadingAnchor, constant: 32),
            titleLabel.trailingAnchor.constraint(equalTo: contentView.trailingAnchor, constant: -32),

            // Host image positioned below title
            hostImageView.topAnchor.constraint(equalTo: titleLabel.bottomAnchor, constant: 16),
            hostImageView.centerXAnchor.constraint(equalTo: contentView.centerXAnchor),
            hostImageView.widthAnchor.constraint(equalToConstant: 40),
            hostImageView.heightAnchor.constraint(equalToConstant: 40),

            // Host name positioned below host image
            hostLabel.topAnchor.constraint(equalTo: hostImageView.bottomAnchor, constant: 8),
            hostLabel.leadingAnchor.constraint(equalTo: contentView.leadingAnchor, constant: 32),
            hostLabel.trailingAnchor.constraint(equalTo: contentView.trailingAnchor, constant: -32),

            // Error view centered
            errorView.centerXAnchor.constraint(equalTo: contentView.centerXAnchor),
            errorView.centerYAnchor.constraint(equalTo: contentView.centerYAnchor),
            errorView.widthAnchor.constraint(equalToConstant: 200),
            errorView.heightAnchor.constraint(equalToConstant: 60),

            errorLabel.centerXAnchor.constraint(equalTo: errorView.centerXAnchor),
            errorLabel.centerYAnchor.constraint(equalTo: errorView.centerYAnchor),
            errorLabel.leadingAnchor.constraint(equalTo: errorView.leadingAnchor, constant: 16),
            errorLabel.trailingAnchor.constraint(equalTo: errorView.trailingAnchor, constant: -16),
        ])

        // MARK: - Gestures
        // Double tap gesture for mute/unmute
        doubleTapGesture = UITapGestureRecognizer(
            target: self, action: #selector(doubleTapGestureRecognized))
        doubleTapGesture?.numberOfTapsRequired = 2
        contentView.addGestureRecognizer(doubleTapGesture!)

        // Single tap gesture
        let tapGesture = UITapGestureRecognizer(target: self, action: #selector(handleTap))
        contentView.addGestureRecognizer(tapGesture)

        // Make single tap wait for double tap
        if let doubleTap = doubleTapGesture {
            tapGesture.require(toFail: doubleTap)
        }
    }

    // MARK: - Aspect Ratio Management

    private func updateVideoAspectRatio(_ aspectRatio: CGFloat) {
        videoAspectRatio = aspectRatio

        // Update height constraint
        videoContainerView.constraints.forEach { constraint in
            if constraint.firstAttribute == .height && constraint.secondAttribute == .width {
                constraint.isActive = false
            }
        }

        // Add new constraint with updated aspect ratio
        let newHeightConstraint = videoContainerView.heightAnchor.constraint(
            equalTo: videoContainerView.widthAnchor,
            multiplier: aspectRatio
        )
        newHeightConstraint.priority = .defaultHigh
        newHeightConstraint.isActive = true

        // Animate the layout change
        UIView.animate(
            withDuration: 0.3, delay: 0, usingSpringWithDamping: 0.8, initialSpringVelocity: 0.2
        ) {
            self.layoutIfNeeded()
        }
    }

    private func detectVideoAspectRatio(from player: AVPlayer) {
        guard let currentItem = player.currentItem else { return }

        // Get video tracks
        let videoTracks = currentItem.tracks.filter { $0.assetTrack?.mediaType == .video }

        if let videoTrack = videoTracks.first,
            let assetTrack = videoTrack.assetTrack
        {

            let size = assetTrack.naturalSize
            let aspectRatio = size.width / size.height

            // Update aspect ratio on main thread
            DispatchQueue.main.async {
                self.updateVideoAspectRatio(aspectRatio)
            }
        }
    }

    private func setupVideoPlayer() {
        // Create AVPlayerLayer
        playerLayer = AVPlayerLayer()
        playerLayer.videoGravity = .resizeAspect  // ← FIXED: Never crop video
        playerLayer.backgroundColor = UIColor.black.cgColor
        videoContainerView.layer.addSublayer(playerLayer)
    }

    override func layoutSubviews() {
        super.layoutSubviews()
        
        // Update gradient layers
        gradientLayer.frame = videoContainerView.bounds
        ambientGradientLayer.frame = colorOverlayView.bounds
        fadeOutMask.frame = backgroundBlurContainer.bounds
        
        // Update player layer
        playerLayer.frame = videoContainerView.bounds
    }

    @objc private func handleTap() {
        // Haptic feedback
        let generator = UIImpactFeedbackGenerator(style: .medium)
        generator.impactOccurred()

        onTap?()
    }

    @objc private func handleDoubleTap() {
        // This method is no longer needed - using doubleTapGestureRecognized instead
    }

    @objc private func doubleTapGestureRecognized() {
        // Toggle mute/unmute
        isMuted.toggle()
        videoPlayerModel?.player.isMuted = isMuted

        // Provide haptic feedback
        let impactFeedback = UIImpactFeedbackGenerator(style: .medium)
        impactFeedback.impactOccurred()

        // Show brief visual feedback
        showMuteFeedback()
    }

    private func showMuteFeedback() {
        // Create temporary mute indicator
        let muteLabel = UILabel()
        muteLabel.text = isMuted ? "🔇 Muted" : "🔊 Unmuted"
        muteLabel.font = .systemFont(ofSize: 16, weight: .semibold)
        muteLabel.textColor = .white
        muteLabel.textAlignment = .center
        muteLabel.backgroundColor = UIColor.black.withAlphaComponent(0.7)
        muteLabel.layer.cornerRadius = 8
        muteLabel.clipsToBounds = true
        muteLabel.translatesAutoresizingMaskIntoConstraints = false

        contentView.addSubview(muteLabel)

        // Position and animate
        NSLayoutConstraint.activate([
            muteLabel.centerXAnchor.constraint(equalTo: contentView.centerXAnchor),
            muteLabel.centerYAnchor.constraint(equalTo: contentView.centerYAnchor),
            muteLabel.widthAnchor.constraint(equalToConstant: 120),
            muteLabel.heightAnchor.constraint(equalToConstant: 40),
        ])

        // Animate in and out
        muteLabel.alpha = 0
        UIView.animate(
            withDuration: 0.2,
            animations: {
                muteLabel.alpha = 1
            }
        ) { _ in
            UIView.animate(
                withDuration: 0.3, delay: 1.0, options: [],
                animations: {
                    muteLabel.alpha = 0
                }
            ) { _ in
                muteLabel.removeFromSuperview()
            }
        }
    }

    // MARK: - Scroll Handling (Simplified for Spotify-style)

    func updateBlurForScrollOffset(_ offset: CGFloat) {
        // Spotify-style: keep blur background stable during scroll
        // The blur background stays in place while content scrolls over it
        backgroundBlurContainer.transform = .identity
        backgroundBlurContainer.alpha = 1.0
    }

    func resetBlurPosition() {
        // Spotify-style: no complex blur animations needed
        backgroundBlurContainer.transform = .identity
        backgroundBlurContainer.alpha = 1.0
    }

    private func extractSpotifyStyleColors(from image: UIImage) -> [UIColor] {
        guard let cgImage = image.cgImage else { return [] }

        // Create a smaller version for faster processing
        let targetSize = CGSize(width: 200, height: 200)
        let renderer = UIGraphicsImageRenderer(size: targetSize)
        let resizedImage = renderer.image { _ in
            image.draw(in: CGRect(origin: .zero, size: targetSize))
        }

        guard let resizedCGImage = resizedImage.cgImage else { return [] }

        // Extract pixel data
        let width = resizedCGImage.width
        let height = resizedCGImage.height
        let bytesPerPixel = 4
        let bytesPerRow = bytesPerPixel * width
        let bitsPerComponent = 8

        var pixelData = [UInt8](repeating: 0, count: width * height * bytesPerPixel)

        guard
            let context = CGContext(
                data: &pixelData,
                width: width,
                height: height,
                bitsPerComponent: bitsPerComponent,
                bytesPerRow: bytesPerRow,
                space: CGColorSpaceCreateDeviceRGB(),
                bitmapInfo: CGImageAlphaInfo.premultipliedLast.rawValue
            )
        else { return [] }

        context.draw(resizedCGImage, in: CGRect(x: 0, y: 0, width: width, height: height))

        // Spotify-style color sampling - focus on vibrant, warm colors
        var colors: [UIColor] = []
        let samplePoints = [
            // Center region (most important)
            CGPoint(x: Double(width) * 0.5, y: Double(height) * 0.4),
            CGPoint(x: Double(width) * 0.4, y: Double(height) * 0.5),
            CGPoint(x: Double(width) * 0.6, y: Double(height) * 0.5),
            CGPoint(x: Double(width) * 0.5, y: Double(height) * 0.6),
            
            // Corner regions for variety
            CGPoint(x: Double(width) * 0.2, y: Double(height) * 0.2),
            CGPoint(x: Double(width) * 0.8, y: Double(height) * 0.2),
            CGPoint(x: Double(width) * 0.2, y: Double(height) * 0.8),
            CGPoint(x: Double(width) * 0.8, y: Double(height) * 0.8),
            
            // Edge regions
            CGPoint(x: Double(width) * 0.1, y: Double(height) * 0.5),
            CGPoint(x: Double(width) * 0.9, y: Double(height) * 0.5),
            CGPoint(x: Double(width) * 0.5, y: Double(height) * 0.1),
            CGPoint(x: Double(width) * 0.5, y: Double(height) * 0.9),
        ]

        for point in samplePoints {
            let x = Int(point.x)
            let y = Int(point.y)
            let pixelIndex = (y * width + x) * bytesPerPixel

            if pixelIndex + 2 < pixelData.count {
                let r = CGFloat(pixelData[pixelIndex]) / 255.0
                let g = CGFloat(pixelData[pixelIndex + 1]) / 255.0
                let b = CGFloat(pixelData[pixelIndex + 2]) / 255.0

                let color = UIColor(red: r, green: g, blue: b, alpha: 1.0)
                colors.append(color)
            }
        }

        // Spotify-style filtering - prioritize warm, vibrant colors
        let filteredColors = colors.filter { color in
            var hue: CGFloat = 0
            var saturation: CGFloat = 0
            var brightness: CGFloat = 0
            var alpha: CGFloat = 0

            color.getHue(&hue, saturation: &saturation, brightness: &brightness, alpha: &alpha)

            // Prefer warm colors (reds, oranges, yellows) and avoid grays
            let isWarmColor = (hue < 0.2 || hue > 0.8) // Red to yellow range
            let isVibrant = saturation > 0.3 && brightness > 0.2 && brightness < 0.9
            let isNotGray = saturation > 0.15 // Avoid grays
            
            return isVibrant && isNotGray
        }

        // Sort by saturation and brightness for best colors first
        let sortedColors = filteredColors.sorted { color1, color2 in
            var h1: CGFloat = 0, s1: CGFloat = 0, b1: CGFloat = 0, a1: CGFloat = 0
            var h2: CGFloat = 0, s2: CGFloat = 0, b2: CGFloat = 0, a2: CGFloat = 0
            
            color1.getHue(&h1, saturation: &s1, brightness: &b1, alpha: &a1)
            color2.getHue(&h2, saturation: &s2, brightness: &b2, alpha: &a2)
            
            // Prioritize higher saturation and moderate brightness
            let score1 = s1 * (1.0 - abs(b1 - 0.6)) // Penalize too dark/light
            let score2 = s2 * (1.0 - abs(b2 - 0.6))
            
            return score1 > score2
        }

        return Array(sortedColors.prefix(3)) // Return top 3 colors
    }

    private func createSpotifyStyleGradient(from colors: [UIColor]) -> CAGradientLayer {
        let gradient = CAGradientLayer()

        if colors.count >= 2 {
            // Use the extracted colors with Spotify-style enhancements
            let enhancedColors = colors.map { color in
                var hue: CGFloat = 0
                var saturation: CGFloat = 0
                var brightness: CGFloat = 0
                var alpha: CGFloat = 0

                color.getHue(&hue, saturation: &saturation, brightness: &brightness, alpha: &alpha)

                // Spotify-style color enhancement
                let enhancedSaturation = min(saturation * 1.3, 1.0)
                let enhancedBrightness = max(min(brightness * 0.7, 0.6), 0.3)
                
                // Create warmer, more ambient version
                return UIColor(
                    hue: hue,
                    saturation: enhancedSaturation,
                    brightness: enhancedBrightness,
                    alpha: 0.6
                )
            }

            gradient.colors = enhancedColors.map { $0.cgColor }
            gradient.locations = (0..<enhancedColors.count).map {
                NSNumber(value: Double($0) / Double(enhancedColors.count - 1))
            }
        } else if let firstColor = colors.first {
            // Single color - create variations
            var hue: CGFloat = 0
            var saturation: CGFloat = 0
            var brightness: CGFloat = 0
            var alpha: CGFloat = 0

            firstColor.getHue(&hue, saturation: &saturation, brightness: &brightness, alpha: &alpha)

            let lighter = UIColor(
                hue: hue,
                saturation: min(saturation * 1.2, 1.0),
                brightness: max(min(brightness * 0.5, 0.4), 0.2),
                alpha: 0.4
            )
            let darker = UIColor(
                hue: hue,
                saturation: min(saturation * 1.4, 1.0),
                brightness: max(min(brightness * 0.8, 0.7), 0.5),
                alpha: 0.7
            )

            gradient.colors = [lighter.cgColor, darker.cgColor]
            gradient.locations = [0.0, 1.0]
        } else {
            // Fallback to Spotify-like default colors
            gradient.colors = [
                UIColor.systemOrange.withAlphaComponent(0.4).cgColor,
                UIColor.systemRed.withAlphaComponent(0.5).cgColor,
                UIColor.systemPink.withAlphaComponent(0.6).cgColor,
            ]
            gradient.locations = [0.0, 0.5, 1.0]
        }

        // Spotify-style gradient direction
        gradient.startPoint = CGPoint(x: 0.0, y: 0.0)
        gradient.endPoint = CGPoint(x: 1.0, y: 1.0)

        return gradient
    }

    private func updateSpotifyStyleBlur(with colors: [UIColor]) {
        // Create Spotify-style gradient for ambient background
        let spotifyGradient = createSpotifyStyleGradient(from: colors)
        spotifyGradient.frame = colorOverlayView.bounds

        // Remove existing gradient layers
        colorOverlayView.layer.sublayers?.removeAll { $0 is CAGradientLayer }

        // Add new gradient
        colorOverlayView.layer.addSublayer(spotifyGradient)

        // Animate the transition
        UIView.animate(
            withDuration: 0.3, delay: 0, usingSpringWithDamping: 0.8, initialSpringVelocity: 0.2
        ) {
            self.colorOverlayView.alpha = 1.0
        }
    }

    private func startColorExtractionTimer() {
        colorExtractionTimer?.invalidate()
        colorExtractionTimer = Timer.scheduledTimer(withTimeInterval: 2.0, repeats: true) {
            [weak self] _ in
            self?.extractColorsFromCurrentContent()
        }
    }

    private func stopColorExtractionTimer() {
        colorExtractionTimer?.invalidate()
        colorExtractionTimer = nil
    }

    private func extractColorsFromVideoFrame() -> [UIColor] {
        guard let player = videoPlayerModel?.player,
            let currentItem = player.currentItem
        else { return [] }

        // For now, we'll use the thumbnail as video frame extraction requires more complex implementation
        // In production, you'd use AVAssetImageGenerator to extract actual video frames
        if let thumbnail = thumbnailImageView.image {
            return extractSpotifyStyleColors(from: thumbnail)
        }

        return []
    }

    private func extractColorsFromCurrentContent() {
        var colors: [UIColor] = []

        // Try to extract from video frame first
        if isPlaying,
            let videoColors = videoPlayerModel?.player.currentItem?.asset != nil
                ? extractColorsFromVideoFrame() : nil
        {
            colors = videoColors
        }

        // Fallback to thumbnail if no video colors or not playing
        if colors.isEmpty, let thumbnail = thumbnailImageView.image {
            colors = extractSpotifyStyleColors(from: thumbnail)
        }

        // Update blur with extracted colors
        if !colors.isEmpty {
            dominantColors = colors
            updateSpotifyStyleBlur(with: colors)
        }
    }

    func configure(with event: LiveActivitiesEvent, appState: AppState) {
        // Store current event
        currentEvent = event

        // Configure UI elements
        titleLabel.text = event.title ?? "Untitled Stream"
        viewerCountLabel.text = formatViewerCount(event.currentParticipants)
        liveBadge.setLive(event.isLive)

        // Configure host info
        if let metadata = appState.metadataEvents[event.pubkey] {
            hostLabel.text =
                metadata.userMetadata?.displayName ?? metadata.userMetadata?.name ?? "Unknown Host"
            if let pictureURL = metadata.userMetadata?.pictureURL {
                hostImageView.kf.setImage(with: pictureURL, options: [.transition(.fade(0.3))])
            }
        } else {
            hostLabel.text = "Loading..."
        }

        // Load thumbnail image for smooth loading experience
        if let imageURL = event.image {
            thumbnailImageView.kf.setImage(with: imageURL) { [weak self] result in
                switch result {
                case .success(_):
                    // Thumbnail loaded successfully, extract colors and setup video
                    self?.extractColorsFromCurrentContent()
                    self?.startColorExtractionTimer()
                    if let streamingURL = event.streaming ?? event.recording {
                        self?.setupVideoStream(url: streamingURL)
                    } else {
                        self?.showErrorState()
                    }
                case .failure(_):
                    // Thumbnail failed, setup video directly
                    if let streamingURL = event.streaming ?? event.recording {
                        self?.setupVideoStream(url: streamingURL)
                    } else {
                        self?.showErrorState()
                    }
                }
            }
        } else {
            // No thumbnail available, setup video directly
            if let streamingURL = event.streaming ?? event.recording {
                setupVideoStream(url: streamingURL)
            } else {
                showErrorState()
            }
        }
    }

    private func setupVideoStream(url: URL) {
        // Only setup once per event
        guard !hasSetupVideo else { return }
        hasSetupVideo = true

        // Show loading
        // loadingIndicator.startAnimating() // Removed for smoother thumbnail experience
        errorView.isHidden = true

        // Create video player model
        videoPlayerModel = VideoPlayerModel(url: url)

        // Configure player layer
        playerLayer.player = videoPlayerModel?.player

        // Detect video aspect ratio after player is set up
        if let player = videoPlayerModel?.player {
            detectVideoAspectRatio(from: player)
        }

        // Setup observers
        setupPlayerObservers()

        // Start playing automatically for live streams
        if currentEvent?.isLive == true {
            videoPlayerModel?.player.play()
            isPlaying = true
        }
    }

    private func setupPlayerObservers() {
        guard let playerModel = videoPlayerModel else { return }

        // Observe player status
        playerModel.player.currentItem?.publisher(for: \.status)
            .receive(on: DispatchQueue.main)
            .sink { [weak self] status in
                self?.handlePlayerStatusChange(status)
            }
            .store(in: &cancellables)

        // Observe playback state
        playerModel.player.publisher(for: \.timeControlStatus)
            .receive(on: DispatchQueue.main)
            .sink { [weak self] status in
                self?.handlePlaybackStatusChange(status)
            }
            .store(in: &cancellables)
    }

    private func handlePlayerStatusChange(_ status: AVPlayerItem.Status) {
        switch status {
        case .readyToPlay:
            // loadingIndicator.stopAnimating() // Removed for smoother thumbnail experience
            errorView.isHidden = true

            // Detect aspect ratio when video is ready
            if let player = videoPlayerModel?.player {
                detectVideoAspectRatio(from: player)
            }

            // Hide thumbnail with smooth transition when video is ready
            UIView.animate(withDuration: 0.3) {
                self.thumbnailImageView.alpha = 0
            }
        case .failed:
            // loadingIndicator.stopAnimating() // Removed for smoother thumbnail experience
            showErrorState()
        case .unknown:
            break
        @unknown default:
            break
        }
    }

    private func handlePlaybackStatusChange(_ status: AVPlayer.TimeControlStatus) {
        switch status {
        case .playing:
            isPlaying = true
            playPauseButton.setImage(UIImage(systemName: "pause.fill"), for: .normal)
            playPauseButton.alpha = 0
        case .paused:
            isPlaying = false
            playPauseButton.setImage(UIImage(systemName: "play.fill"), for: .normal)
            playPauseButton.alpha = 1
        case .waitingToPlayAtSpecifiedRate:
            break
        @unknown default:
            break
        }
    }

    private func showErrorState() {
        loadingIndicator.stopAnimating()
        errorView.isHidden = false
    }

    private func formatViewerCount(_ count: Int) -> String {
        if count >= 1000 {
            return String(format: "%.1fK watching", Double(count) / 1000.0)
        }
        return "\(count) watching"
    }

    override func prepareForReuse() {
        super.prepareForReuse()

        // Cleanup video
        videoPlayerModel?.player.pause()
        videoPlayerModel = nil
        playerLayer.player = nil

        // Clear observers
        cancellables.removeAll()

        // Reset UI
        titleLabel.text = nil
        hostLabel.text = nil
        hostImageView.image = nil
        viewerCountLabel.text = nil
        thumbnailImageView.image = nil
        thumbnailImageView.alpha = 1
        errorView.isHidden = true
        isPlaying = false
        isMuted = true
        hasSetupVideo = false
        onTap = nil

        // Cleanup Spotify-style blur effects
        stopColorExtractionTimer()
        dominantColors.removeAll()
        colorOverlayView.layer.sublayers?.removeAll { $0 is CAGradientLayer }
        colorOverlayView.alpha = 0

        // Reset blur position
        resetBlurPosition()
    }
}

// MARK: - Carousel Cell
private final class CarouselCell: UICollectionViewCell {
    static let reuseIdentifier = "CarouselCell"

    private let containerView = UIView()
    private let imageView = UIImageView()
    private let liveBadge = LiveBadgeView()
    private let viewerCountLabel = UILabel()
    private let titleLabel = UILabel()
    private let hostLabel = UILabel()
    private let hostImageView = UIImageView()

    var onTap: (() -> Void)?

    override init(frame: CGRect) {
        super.init(frame: frame)
        setupUI()
    }

    required init?(coder: NSCoder) {
        fatalError("init(coder:) has not been implemented")
    }

    private func setupUI() {
        // Container for shadow
        containerView.backgroundColor = .clear
        containerView.translatesAutoresizingMaskIntoConstraints = false
        contentView.addSubview(containerView)

        // Image view
        imageView.contentMode = .scaleAspectFill
        imageView.clipsToBounds = true
        imageView.backgroundColor = .systemGray6
        imageView.layer.cornerRadius = 12
        imageView.translatesAutoresizingMaskIntoConstraints = false
        containerView.addSubview(imageView)

        // Add shadow to container
        containerView.layer.shadowColor = UIColor.black.cgColor
        containerView.layer.shadowOffset = CGSize(width: 0, height: 4)
        containerView.layer.shadowRadius = 12
        containerView.layer.shadowOpacity = 0.15

        // Live badge
        liveBadge.translatesAutoresizingMaskIntoConstraints = false
        imageView.addSubview(liveBadge)

        // Viewer count
        viewerCountLabel.font = .systemFont(ofSize: 12, weight: .semibold)
        viewerCountLabel.textColor = .white
        viewerCountLabel.translatesAutoresizingMaskIntoConstraints = false
        imageView.addSubview(viewerCountLabel)

        // Info container
        let infoContainer = UIView()
        infoContainer.translatesAutoresizingMaskIntoConstraints = false
        containerView.addSubview(infoContainer)

        // Host image
        hostImageView.contentMode = .scaleAspectFill
        hostImageView.clipsToBounds = true
        hostImageView.backgroundColor = .systemGray5
        hostImageView.layer.cornerRadius = 16
        hostImageView.translatesAutoresizingMaskIntoConstraints = false
        infoContainer.addSubview(hostImageView)

        // Title
        titleLabel.font = .systemFont(ofSize: 15, weight: .semibold)
        titleLabel.textColor = .label
        titleLabel.numberOfLines = 2
        titleLabel.translatesAutoresizingMaskIntoConstraints = false
        infoContainer.addSubview(titleLabel)

        // Host name
        hostLabel.font = .systemFont(ofSize: 13, weight: .regular)
        hostLabel.textColor = .secondaryLabel
        hostLabel.translatesAutoresizingMaskIntoConstraints = false
        infoContainer.addSubview(hostLabel)

        NSLayoutConstraint.activate([
            containerView.topAnchor.constraint(equalTo: contentView.topAnchor),
            containerView.leadingAnchor.constraint(equalTo: contentView.leadingAnchor),
            containerView.trailingAnchor.constraint(equalTo: contentView.trailingAnchor),
            containerView.bottomAnchor.constraint(equalTo: contentView.bottomAnchor),

            imageView.topAnchor.constraint(equalTo: containerView.topAnchor),
            imageView.leadingAnchor.constraint(equalTo: containerView.leadingAnchor),
            imageView.trailingAnchor.constraint(equalTo: containerView.trailingAnchor),
            imageView.heightAnchor.constraint(
                equalTo: containerView.heightAnchor, multiplier: 0.62),

            liveBadge.topAnchor.constraint(equalTo: imageView.topAnchor, constant: 8),
            liveBadge.leadingAnchor.constraint(equalTo: imageView.leadingAnchor, constant: 8),

            viewerCountLabel.centerYAnchor.constraint(equalTo: liveBadge.centerYAnchor),
            viewerCountLabel.leadingAnchor.constraint(
                equalTo: liveBadge.trailingAnchor, constant: 8),

            infoContainer.topAnchor.constraint(equalTo: imageView.bottomAnchor, constant: 8),
            infoContainer.leadingAnchor.constraint(
                equalTo: containerView.leadingAnchor, constant: 8),
            infoContainer.trailingAnchor.constraint(
                equalTo: containerView.trailingAnchor, constant: -8),
            infoContainer.bottomAnchor.constraint(
                lessThanOrEqualTo: containerView.bottomAnchor, constant: -8),

            hostImageView.topAnchor.constraint(equalTo: infoContainer.topAnchor),
            hostImageView.leadingAnchor.constraint(equalTo: infoContainer.leadingAnchor),
            hostImageView.widthAnchor.constraint(equalToConstant: 32),
            hostImageView.heightAnchor.constraint(equalToConstant: 32),

            titleLabel.topAnchor.constraint(equalTo: infoContainer.topAnchor),
            titleLabel.leadingAnchor.constraint(equalTo: hostImageView.trailingAnchor, constant: 8),
            titleLabel.trailingAnchor.constraint(equalTo: infoContainer.trailingAnchor),

            hostLabel.topAnchor.constraint(equalTo: titleLabel.bottomAnchor, constant: 2),
            hostLabel.leadingAnchor.constraint(equalTo: titleLabel.leadingAnchor),
            hostLabel.trailingAnchor.constraint(equalTo: infoContainer.trailingAnchor),
            hostLabel.bottomAnchor.constraint(lessThanOrEqualTo: infoContainer.bottomAnchor),
        ])

        // Add tap gesture
        let tapGesture = UITapGestureRecognizer(target: self, action: #selector(handleTap))
        contentView.addGestureRecognizer(tapGesture)
    }

    @objc private func handleTap() {
        // Add scale animation
        UIView.animate(
            withDuration: 0.1,
            animations: {
                self.transform = CGAffineTransform(scaleX: 0.95, y: 0.95)
            },
            completion: { _ in
                UIView.animate(withDuration: 0.1) {
                    self.transform = .identity
                }
                self.onTap?()
            })
    }

    func configure(with event: LiveActivitiesEvent, appState: AppState) {
        // Image
        if let imageURLString = event.image {
            imageView.kf.setImage(
                with: imageURLString,
                options: [
                    .transition(.fade(0.2)),
                    .cacheOriginalImage,
                ])
        }

        // Title
        titleLabel.text = event.title ?? "Untitled Stream"

        // Viewer count
        viewerCountLabel.text = "\(event.currentParticipants)"

        // Host name
        if let metadata = appState.metadataEvents[event.pubkey] {
            hostLabel.text =
                metadata.userMetadata?.displayName ?? metadata.userMetadata?.name ?? "Unknown"
            // Load host image if available
            if let pictureURL = metadata.userMetadata?.pictureURL {
                hostImageView.kf.setImage(with: pictureURL, options: [.transition(.fade(0.2))])
            }
        } else {
            hostLabel.text = "Loading..."
        }

        // Live badge
        liveBadge.setLive(event.isLive)
    }

    override func prepareForReuse() {
        super.prepareForReuse()
        imageView.image = nil
        hostImageView.image = nil
        titleLabel.text = nil
        hostLabel.text = nil
        onTap = nil
    }
}

// MARK: - Section Header View
private final class SectionHeaderView: UICollectionReusableView {
    static let reuseIdentifier = "SectionHeaderView"

    private let titleLabel = UILabel()
    private let subtitleLabel = UILabel()

    override init(frame: CGRect) {
        super.init(frame: frame)
        setupUI()
    }

    required init?(coder: NSCoder) {
        fatalError("init(coder:) has not been implemented")
    }

    private func setupUI() {
        titleLabel.font = .systemFont(ofSize: 22, weight: .bold)
        titleLabel.textColor = .label
        titleLabel.translatesAutoresizingMaskIntoConstraints = false
        addSubview(titleLabel)

        subtitleLabel.font = .systemFont(ofSize: 14, weight: .medium)
        subtitleLabel.textColor = .secondaryLabel
        subtitleLabel.translatesAutoresizingMaskIntoConstraints = false
        addSubview(subtitleLabel)

        NSLayoutConstraint.activate([
            titleLabel.leadingAnchor.constraint(equalTo: leadingAnchor, constant: 16),
            titleLabel.topAnchor.constraint(equalTo: topAnchor, constant: 8),

            subtitleLabel.leadingAnchor.constraint(equalTo: titleLabel.leadingAnchor),
            subtitleLabel.topAnchor.constraint(equalTo: titleLabel.bottomAnchor, constant: 2),
            subtitleLabel.bottomAnchor.constraint(lessThanOrEqualTo: bottomAnchor, constant: -8),
        ])
    }

    func configure(title: String, subtitle: String?) {
        titleLabel.text = title
        subtitleLabel.text = subtitle
        subtitleLabel.isHidden = subtitle == nil
    }
}

// MARK: - Live Badge View
private final class LiveBadgeView: UIView {
    private let dotView = UIView()
    private let label = UILabel()
    private var isLive = true

    override init(frame: CGRect) {
        super.init(frame: frame)
        setupUI()
    }

    required init?(coder: NSCoder) {
        fatalError("init(coder:) has not been implemented")
    }

    private func setupUI() {
        backgroundColor = UIColor.systemRed.withAlphaComponent(0.9)
        layer.cornerRadius = 12

        // Pulsing dot
        dotView.backgroundColor = .white
        dotView.layer.cornerRadius = 3
        dotView.translatesAutoresizingMaskIntoConstraints = false
        addSubview(dotView)

        // Label
        label.text = "LIVE"
        label.font = .systemFont(ofSize: 11, weight: .bold)
        label.textColor = .white
        label.translatesAutoresizingMaskIntoConstraints = false
        addSubview(label)

        NSLayoutConstraint.activate([
            dotView.leadingAnchor.constraint(equalTo: leadingAnchor, constant: 8),
            dotView.centerYAnchor.constraint(equalTo: centerYAnchor),
            dotView.widthAnchor.constraint(equalToConstant: 6),
            dotView.heightAnchor.constraint(equalToConstant: 6),

            label.leadingAnchor.constraint(equalTo: dotView.trailingAnchor, constant: 6),
            label.trailingAnchor.constraint(equalTo: trailingAnchor, constant: -8),
            label.centerYAnchor.constraint(equalTo: centerYAnchor),

            heightAnchor.constraint(equalToConstant: 24),
        ])

        startPulseAnimation()
    }

    func setLive(_ live: Bool) {
        isLive = live
        if live {
            backgroundColor = UIColor.systemRed.withAlphaComponent(0.9)
            label.text = "LIVE"
            startPulseAnimation()
        } else {
            backgroundColor = UIColor.systemGray.withAlphaComponent(0.9)
            label.text = "ENDED"
            dotView.layer.removeAllAnimations()
        }
    }

    private func startPulseAnimation() {
        guard isLive else { return }

        let animation = CABasicAnimation(keyPath: "opacity")
        animation.fromValue = 1.0
        animation.toValue = 0.3
        animation.duration = 1.0
        animation.autoreverses = true
        animation.repeatCount = .infinity
        dotView.layer.add(animation, forKey: "pulse")
    }
}
