import AVKit
import Combine
import Kingfisher
import NostrSDK
import UIKit

/// A modern, engaging video discovery interface with a hero section and horizontal carousels
final class VideoListViewController: UIViewController {

    // MARK: - Dependencies
    private let appState: AppState
    private let orientationMonitor: OrientationMonitor

    // MARK: - UI Components
    private let collectionView: UICollectionView
    private let refreshControl = UIRefreshControl()
    private let heroGradientView = UIView()
    private let headerView = AmbientHeader()

    // MARK: - Scroll Tracking
    private var topBarHeight: CGFloat = 100
    private var barsMaxTransform: CGFloat { topBarHeight }
    private var prevPosition: CGFloat = 0
    private var prevTransform: CGFloat = 0

    // MARK: - Data
    private var cancellables = Set<AnyCancellable>()
    private var sections: [ContentSection] = []
    private var isLoading = false
    private var hasSetInitialInset = false

    // MARK: - Layout
    private enum LayoutMetrics {
        static var heroHeight: CGFloat {
            // Dynamic hero height based on screen size - reduced for better proportions
            let screenWidth = UIScreen.main.bounds.width

            // Calculate height as a ratio of screen width for good proportions
            // Use 0.85:1 ratio (more compact, less dominant)
            let calculatedHeight = screenWidth * 0.85

            // Apply constraints - reduced max height
            let minHeight: CGFloat = 250
            let maxHeight: CGFloat = 320

            return min(max(calculatedHeight, minHeight), maxHeight)
        }

        static let carouselHeight: CGFloat = 240
        static let sectionHeaderHeight: CGFloat = 60
        static let spacing: CGFloat = 16
        static let cardCornerRadius: CGFloat = 16
    }

    // MARK: - Data Models
    struct ContentSection {
        let title: String
        let subtitle: String?
        let events: [LiveActivitiesEvent]
        let style: SectionStyle

        enum SectionStyle {
            case hero  // Large featured content at the top
            case carousel  // Horizontal scrolling cards
            case grid  // Grid layout for more content
        }
    }

    // MARK: - Initialization
    init(appState: AppState, orientationMonitor: OrientationMonitor) {
        self.appState = appState
        self.orientationMonitor = orientationMonitor

        // Setup collection view layout
        let layout = UICollectionViewCompositionalLayout { sectionIndex, environment in
            return VideoListViewController.createLayout(for: sectionIndex, environment: environment)
        }

        self.collectionView = UICollectionView(frame: .zero, collectionViewLayout: layout)

        super.init(nibName: nil, bundle: nil)
    }

    required init?(coder: NSCoder) {
        fatalError("init(coder:) has not been implemented")
    }

    // MARK: - Lifecycle
    override func viewDidLoad() {
        super.viewDidLoad()
        setupUI()
        setupHeader()
        setupCollectionView()
        setupObservers()
        rebuildSections()

        // Add a subtle entrance animation
        collectionView.alpha = 0
        headerView.alpha = 0
        UIView.animate(withDuration: 0.4, delay: 0.1, options: .curveEaseOut) {
            self.collectionView.alpha = 1
            self.headerView.alpha = 1
        }
    }

    override func viewWillAppear(_ animated: Bool) {
        super.viewWillAppear(animated)
        navigationController?.setNavigationBarHidden(true, animated: animated)
    }

    override func viewDidLayoutSubviews() {
        super.viewDidLayoutSubviews()

        // Calculate header height based on safe area
        let safeAreaTop = view.safeAreaInsets.top
        topBarHeight = safeAreaTop + 60 - 12 

        // Override any additionalSafeAreaInsets that might be set by parent controllers
        if additionalSafeAreaInsets != .zero {
            additionalSafeAreaInsets = .zero
        }

        // FIXED: Add top content inset to push content below header
        // This creates space for the header so content starts right below it
        if !hasSetInitialInset {
            // Add top inset equal to header height
            collectionView.contentInset = .init(
                top: topBarHeight,  // ← FIXED: Push content below header
                left: 0,
                bottom: 150,  // Bottom padding for tab bar
                right: 0
            )

            // Set initial offset to negative of top inset
            // This makes content appear to start at top, but actually starts below header
            collectionView.contentOffset = .init(x: 0, y: -topBarHeight)

            // Scroll indicators account for header space
            collectionView.scrollIndicatorInsets = .init(
                top: topBarHeight,  // ← FIXED: Account for header
                left: 0,
                bottom: 150,
                right: 0
            )

            hasSetInitialInset = true
        }
    }

    override func viewWillDisappear(_ animated: Bool) {
        super.viewWillDisappear(animated)

        // Always show bars when leaving
        if prevTransform != 0 {
            if animated {
                animateBarsToVisible()
            } else {
                setBarsToTransform(0)
            }
        }
    }

    // MARK: - UI Setup
    private func setupUI() {
        view.backgroundColor = .systemBackground

        // Setup collection view
        collectionView.backgroundColor = .systemBackground
        collectionView.showsVerticalScrollIndicator = false
        collectionView.contentInsetAdjustmentBehavior = .never
        collectionView.translatesAutoresizingMaskIntoConstraints = false
        collectionView.delegate = self
        collectionView.dataSource = self

        // Setup refresh control
        refreshControl.tintColor = .label
        refreshControl.addTarget(self, action: #selector(handleRefresh), for: .valueChanged)
        collectionView.refreshControl = refreshControl

        view.addSubview(collectionView)

        NSLayoutConstraint.activate([
            collectionView.topAnchor.constraint(equalTo: view.topAnchor),
            collectionView.leadingAnchor.constraint(equalTo: view.leadingAnchor),
            collectionView.trailingAnchor.constraint(equalTo: view.trailingAnchor),
            collectionView.bottomAnchor.constraint(equalTo: view.bottomAnchor),
        ])
    }

    private func setupHeader() {
        // Add header above collection view
        view.addSubview(headerView)
        headerView.translatesAutoresizingMaskIntoConstraints = false

        NSLayoutConstraint.activate([
            headerView.topAnchor.constraint(equalTo: view.topAnchor),
            headerView.leadingAnchor.constraint(equalTo: view.leadingAnchor),
            headerView.trailingAnchor.constraint(equalTo: view.trailingAnchor),
            headerView.heightAnchor.constraint(equalToConstant: topBarHeight),
        ])

        // Bring header to front
        view.bringSubviewToFront(headerView)

        // Configure callbacks
        headerView.onSearchTapped = { [weak self] in
            self?.showSearch()
        }

        headerView.onLogoTapped = { [weak self] in
            self?.scrollToTopAndRefresh()
        }

        headerView.onLiveIndicatorTapped = { [weak self] in
            self?.scrollToLiveSection()
        }

        // Update live count
        let liveCount = appState.liveActivitiesEvents.values.flatMap { $0 }.filter { $0.isLive }
            .count
        headerView.setLiveCount(liveCount)
    }

    private func setupCollectionView() {
        // Register cells
        collectionView.register(HeroCell.self, forCellWithReuseIdentifier: HeroCell.reuseIdentifier)
        collectionView.register(
            CarouselCell.self, forCellWithReuseIdentifier: CarouselCell.reuseIdentifier)
        collectionView.register(
            SectionHeaderView.self,
            forSupplementaryViewOfKind: UICollectionView.elementKindSectionHeader,
            withReuseIdentifier: SectionHeaderView.reuseIdentifier)
    }

    // MARK: - Compositional Layout
    private static func createLayout(
        for sectionIndex: Int, environment: NSCollectionLayoutEnvironment
    ) -> NSCollectionLayoutSection {
        // This will be called per section, but we need to know the section style
        // For now, we'll use a more flexible approach

        if sectionIndex == 0 {
            // Hero section - full width, large height
            return createHeroSection()
        } else {
            // Carousel section - horizontal scrolling
            return createCarouselSection()
        }
    }

    private static func createHeroSection() -> NSCollectionLayoutSection {
        let itemSize = NSCollectionLayoutSize(
            widthDimension: .fractionalWidth(1.0),
            heightDimension: .fractionalHeight(1.0)
        )
        let item = NSCollectionLayoutItem(layoutSize: itemSize)

        let groupSize = NSCollectionLayoutSize(
            widthDimension: .fractionalWidth(1.0),
            heightDimension: .absolute(LayoutMetrics.heroHeight)
        )
        let group = NSCollectionLayoutGroup.horizontal(layoutSize: groupSize, subitems: [item])

        let section = NSCollectionLayoutSection(group: group)
        section.contentInsets = NSDirectionalEdgeInsets(top: 0, leading: 0, bottom: 20, trailing: 0)

        return section
    }

    private static func createCarouselSection() -> NSCollectionLayoutSection {
        let itemSize = NSCollectionLayoutSize(
            widthDimension: .fractionalWidth(1.0),
            heightDimension: .fractionalHeight(1.0)
        )
        let item = NSCollectionLayoutItem(layoutSize: itemSize)

        let groupSize = NSCollectionLayoutSize(
            widthDimension: .absolute(280),
            heightDimension: .absolute(LayoutMetrics.carouselHeight)
        )
        let group = NSCollectionLayoutGroup.horizontal(layoutSize: groupSize, subitems: [item])

        let section = NSCollectionLayoutSection(group: group)
        section.orthogonalScrollingBehavior = .continuousGroupLeadingBoundary
        section.interGroupSpacing = 12
        section.contentInsets = NSDirectionalEdgeInsets(
            top: 0, leading: 16, bottom: 24, trailing: 16)

        // Add section header
        let headerSize = NSCollectionLayoutSize(
            widthDimension: .fractionalWidth(1.0),
            heightDimension: .absolute(LayoutMetrics.sectionHeaderHeight)
        )
        let header = NSCollectionLayoutBoundarySupplementaryItem(
            layoutSize: headerSize,
            elementKind: UICollectionView.elementKindSectionHeader,
            alignment: .top
        )
        section.boundarySupplementaryItems = [header]

        return section
    }

    // MARK: - Observers
    private func setupObservers() {
        // Observe live activities changes
        appState.$liveActivitiesEvents
            .debounce(for: .milliseconds(300), scheduler: DispatchQueue.main)
            .sink { [weak self] _ in
                self?.rebuildSections()
            }
            .store(in: &cancellables)

        // Observe followed pubkeys changes
        appState.$followedPubkeys
            .debounce(for: .milliseconds(300), scheduler: DispatchQueue.main)
            .sink { [weak self] _ in
                self?.rebuildSections()
            }
            .store(in: &cancellables)
    }

    // MARK: - Data Management
    private func rebuildSections() {
        let allEvents = appState.liveActivitiesEvents.values.flatMap { $0 }
        let liveEvents = allEvents.filter { $0.isLive }
        let replayEvents = allEvents.filter { $0.isReplay }

        var newSections: [ContentSection] = []

        // 1. Hero Section - Top live stream
        if let topLiveEvent = liveEvents.sorted(by: {
            $0.currentParticipants > $1.currentParticipants
        }).first {
            newSections.append(
                ContentSection(
                    title: "Featured Live",
                    subtitle: nil,
                    events: [topLiveEvent],
                    style: .hero
                ))
        }

        // 2. Live Now - Top live streams
        if liveEvents.count > 1 {
            let topLive = Array(
                liveEvents.sorted { $0.currentParticipants > $1.currentParticipants }.prefix(10))
            newSections.append(
                ContentSection(
                    title: "Live Now",
                    subtitle: "\(liveEvents.count) streams",
                    events: topLive,
                    style: .carousel
                ))
        }

        // 3. Following
        if let publicKey = appState.publicKey {
            let followedPubkeys = appState.followedPubkeys
            let followedEvents = liveEvents.filter { event in
                if followedPubkeys.contains(event.pubkey) { return true }
                let hostHex = event.participants.first(where: { $0.role?.lowercased() == "host" })?
                    .pubkey?.hex
                return hostHex != nil && followedPubkeys.contains(hostHex!)
            }

            if !followedEvents.isEmpty {
                newSections.append(
                    ContentSection(
                        title: "Following",
                        subtitle: "\(followedEvents.count) live",
                        events: followedEvents.sorted {
                            $0.currentParticipants > $1.currentParticipants
                        },
                        style: .carousel
                    ))
            }
        }

        // 4. Category Sections
        var tagMap: [String: [LiveActivitiesEvent]] = [:]
        for event in liveEvents {
            for rawTag in event.internalTags {
                let tagName = rawTag.replacingOccurrences(of: "internal:", with: "")
                tagMap[tagName, default: []].append(event)
            }
        }

        let categorySections = tagMap.compactMap { tagName, events -> ContentSection? in
            guard !events.isEmpty else { return nil }
            let sorted = events.sorted { $0.currentParticipants > $1.currentParticipants }
            return ContentSection(
                title: tagName.capitalized,
                subtitle: "\(sorted.count) streams",
                events: sorted,
                style: .carousel
            )
        }.sorted { lhs, rhs in
            (lhs.events.first?.currentParticipants ?? 0)
                > (rhs.events.first?.currentParticipants ?? 0)
        }

        newSections.append(contentsOf: categorySections)

        // 5. Recent Replays
        if !replayEvents.isEmpty {
            let sortedReplays = Array(
                replayEvents.sorted { $0.createdAt > $1.createdAt }.prefix(10))
            newSections.append(
                ContentSection(
                    title: "Recent Replays",
                    subtitle: "\(replayEvents.count) available",
                    events: sortedReplays,
                    style: .carousel
                ))
        }

        sections = newSections

        UIView.transition(with: collectionView, duration: 0.3, options: .transitionCrossDissolve) {
            self.collectionView.reloadData()
        }
    }

    // MARK: - Actions
    @objc private func handleRefresh() {
        appState.refresh(hardRefresh: true)

        // Haptic feedback
        let generator = UIImpactFeedbackGenerator(style: .medium)
        generator.impactOccurred()

        DispatchQueue.main.asyncAfter(deadline: .now() + 1.0) {
            self.refreshControl.endRefreshing()
        }
    }

    private func didSelectEvent(_ event: LiveActivitiesEvent) {
        // Haptic feedback
        let generator = UIImpactFeedbackGenerator(style: .light)
        generator.impactOccurred()

        // Set up and show the player
        appState.playerConfig.selectedLiveActivitiesEvent = event
        appState.playerConfig.setupSharedVideoPlayer(for: event)
        appState.playerConfig.showMiniPlayer = true

        // Subtle animation feedback
        UIView.animate(
            withDuration: 0.2,
            animations: {
                // Could add a subtle scale animation here if desired
            })
    }

    // MARK: - Header Actions

    private func showSearch() {
        // TODO: Implement search view
        print("🔍 Search tapped")

        // Haptic feedback
        let generator = UIImpactFeedbackGenerator(style: .light)
        generator.impactOccurred()
    }

    private func scrollToTopAndRefresh() {
        // Scroll to top with animation
        collectionView.setContentOffset(.zero, animated: true)

        // Trigger refresh
        appState.refresh(hardRefresh: true)

        // Haptic feedback
        let generator = UIImpactFeedbackGenerator(style: .medium)
        generator.impactOccurred()
    }

    private func scrollToLiveSection() {
        // Find "Live Now" section and scroll to it
        if let liveSection = sections.firstIndex(where: { $0.title == "Live Now" }) {
            let indexPath = IndexPath(item: 0, section: liveSection)
            collectionView.scrollToItem(at: indexPath, at: .top, animated: true)
        }

        // Haptic feedback
        let generator = UIImpactFeedbackGenerator(style: .light)
        generator.impactOccurred()
    }

    // MARK: - Transform Methods

    private func setBarsToTransform(_ transform: CGFloat) {
        prevTransform = transform

        // Transform header up
        headerView.transform = .init(translationX: 0, y: transform)

        // Transform tab bar down (NEGATIVE transform to move down)
        mainTabBarController?.vStack.transform = .init(translationX: 0, y: -transform)

        // Update header visibility
        let percent = abs(transform / barsMaxTransform)
        headerView.updateVisibility(percent: percent)
    }

    private func animateBarsToTransform(_ transform: CGFloat) {
        UIView.animate(withDuration: 0.2, delay: 0, options: [.curveEaseOut]) {
            self.setBarsToTransform(transform)
        }
    }

    private func animateBarsToVisible() {
        animateBarsToTransform(0)
    }

    private func animateBarsToInvisible() {
        animateBarsToTransform(-barsMaxTransform)
    }

    private func setBarsDependingOnPosition() {
        // Snap to hidden if more than 50% hidden and not at top
        if prevTransform < -(barsMaxTransform / 2) && collectionView.contentOffset.y > 0 {
            animateBarsToInvisible()
        } else {
            animateBarsToVisible()
        }
    }
}

// MARK: - UICollectionViewDataSource
extension VideoListViewController: UICollectionViewDataSource {
    func numberOfSections(in collectionView: UICollectionView) -> Int {
        return sections.count
    }

    func collectionView(_ collectionView: UICollectionView, numberOfItemsInSection section: Int)
        -> Int
    {
        let sectionData = sections[section]
        return sectionData.style == .hero ? 1 : sectionData.events.count
    }

    func collectionView(_ collectionView: UICollectionView, cellForItemAt indexPath: IndexPath)
        -> UICollectionViewCell
    {
        let section = sections[indexPath.section]

        switch section.style {
        case .hero:
            let cell =
                collectionView.dequeueReusableCell(
                    withReuseIdentifier: HeroCell.reuseIdentifier, for: indexPath) as! HeroCell
            if let event = section.events.first {
                cell.configure(with: event, appState: appState)
                cell.onTap = { [weak self] in
                    self?.didSelectEvent(event)
                }
            }
            return cell

        case .carousel, .grid:
            let cell =
                collectionView.dequeueReusableCell(
                    withReuseIdentifier: CarouselCell.reuseIdentifier, for: indexPath)
                as! CarouselCell
            let event = section.events[indexPath.item]
            cell.configure(with: event, appState: appState)
            cell.onTap = { [weak self] in
                self?.didSelectEvent(event)
            }
            return cell
        }
    }

    func collectionView(
        _ collectionView: UICollectionView, viewForSupplementaryElementOfKind kind: String,
        at indexPath: IndexPath
    ) -> UICollectionReusableView {
        guard kind == UICollectionView.elementKindSectionHeader else {
            return UICollectionReusableView()
        }

        let header =
            collectionView.dequeueReusableSupplementaryView(
                ofKind: kind,
                withReuseIdentifier: SectionHeaderView.reuseIdentifier,
                for: indexPath
            ) as! SectionHeaderView

        let section = sections[indexPath.section]
        header.configure(title: section.title, subtitle: section.subtitle)

        return header
    }
}

// MARK: - UICollectionViewDelegate
extension VideoListViewController: UICollectionViewDelegate {
    func collectionView(_ collectionView: UICollectionView, didSelectItemAt indexPath: IndexPath) {
        let section = sections[indexPath.section]
        let event = section.style == .hero ? section.events[0] : section.events[indexPath.item]
        didSelectEvent(event)
    }

    // MARK: - Scroll Handling

    func scrollViewDidScroll(_ scrollView: UIScrollView) {
        let offset = scrollView.contentOffset.y

        // EXISTING: Update hero cell blur
        if let heroCell = collectionView.cellForItem(at: IndexPath(item: 0, section: 0))
            as? HeroCell
        {
            heroCell.updateBlurForScrollOffset(offset)
        }

        // NEW: Bar transforms
        let newPosition = scrollView.contentOffset.y
        let delta = newPosition - prevPosition
        prevPosition = newPosition

        // Guard 1: Ignore large jumps
        if abs(delta) > 50 { return }

        // Calculate transform
        let theoreticalNewTransform = (prevTransform - delta).clamped(to: -barsMaxTransform...0)

        // Guard 2: Pull-to-refresh override - force visible when at or above top
        // When contentOffset.y <= -topBarHeight, user is at or above resting position
        // This prevents bars from bouncing when user pulls down at top!
        let newTransform = newPosition <= -topBarHeight ? 0 : theoreticalNewTransform

        setBarsToTransform(newTransform)
    }

    func scrollViewDidEndDragging(_ scrollView: UIScrollView, willDecelerate decelerate: Bool) {
        // EXISTING: Reset hero blur
        if !decelerate {
            if let heroCell = collectionView.cellForItem(at: IndexPath(item: 0, section: 0))
                as? HeroCell
            {
                heroCell.resetBlurPosition()
            }
        }

        // NEW: Snap bars to position
        if !decelerate {
            setBarsDependingOnPosition()
        }
    }

    func scrollViewDidEndDecelerating(_ scrollView: UIScrollView) {
        // EXISTING: Reset hero blur
        if let heroCell = collectionView.cellForItem(at: IndexPath(item: 0, section: 0))
            as? HeroCell
        {
            heroCell.resetBlurPosition()
        }

        // NEW: Snap bars to position
        setBarsDependingOnPosition()
    }

    func scrollViewShouldScrollToTop(_ scrollView: UIScrollView) -> Bool {
        // Always show bars when tapping status bar to scroll to top
        animateBarsToVisible()
        return true
    }
}

// MARK: - Hero Cell with Spotify-Style Album View
private final class HeroCell: UICollectionViewCell {
    static let reuseIdentifier = "HeroCell"

    // MARK: - Background Blur Components (Spotify-style)
    private let backgroundBlurContainer = UIView()
    private let backgroundBlurView = UIVisualEffectView(effect: UIBlurEffect(style: .systemUltraThinMaterial))
    private let colorOverlayView = UIView()
    private let ambientGradientLayer = CAGradientLayer()
    private let fadeOutMask = CAGradientLayer()
    
    // MARK: - Centered Video/Thumbnail (Album Cover Style)
    private let videoContainerView = UIView()
    private var playerLayer: AVPlayerLayer!
    private var videoPlayerModel: VideoPlayerModel?
    private var currentEvent: LiveActivitiesEvent?
    private var cancellables = Set<AnyCancellable>()
    private let thumbnailImageView = UIImageView()
    
    // MARK: - Video Properties
    private var videoAspectRatio: CGFloat = 1.0  // Square aspect ratio like album covers
    private var videoSize: CGFloat = 280  // Fixed size for album cover style
    
    // MARK: - Color Extraction
    private var dominantColors: [UIColor] = []
    private var colorExtractionTimer: Timer?
    
    // MARK: - UI Overlay Components
    private let gradientLayer = CAGradientLayer()
    private let liveBadge = LiveBadgeView()
    private let viewerCountLabel = UILabel()
    private let titleLabel = UILabel()
    private let hostLabel = UILabel()
    private let hostImageView = UIImageView()
    private let errorView = UIView()
    private let errorLabel = UILabel()

    // MARK: - Interaction
    var onTap: (() -> Void)?
    private var isPlaying = false
    private var hasSetupVideo = false
    private var isMuted = true
    private var doubleTapGesture: UITapGestureRecognizer?

    override init(frame: CGRect) {
        super.init(frame: frame)
        setupUI()
        setupVideoPlayer()
    }

    required init?(coder: NSCoder) {
        fatalError("init(coder:) has not been implemented")
    }
}

// MARK: - Carousel Cell
private final class CarouselCell: UICollectionViewCell {

        // Thumbnail image view - shows while video loads
        thumbnailImageView.contentMode = .scaleAspectFill
        thumbnailImageView.clipsToBounds = true
        thumbnailImageView.backgroundColor = .systemGray6
        thumbnailImageView.translatesAutoresizingMaskIntoConstraints = false
        videoContainerView.addSubview(thumbnailImageView)

        // Dynamic blur container - positioned above video
        blurContainerView.translatesAutoresizingMaskIntoConstraints = false
        contentView.addSubview(blurContainerView)

        // Gradient blend layer - smooth transition from content to blur
        gradientBlendLayer.colors = [
            UIColor.clear.cgColor, UIColor.black.withAlphaComponent(0.3).cgColor,
        ]
        gradientBlendLayer.locations = [0.0, 1.0]
        gradientBlendLayer.startPoint = CGPoint(x: 0.5, y: 0.0)
        gradientBlendLayer.endPoint = CGPoint(x: 0.5, y: 1.0)
        blurContainerView.layer.addSublayer(gradientBlendLayer)

        // Blur fade-out mask - creates smooth, gradual alpha transition
        // Multi-stop gradient for silky-smooth blending with video
        blurFadeOutMask.colors = [
            UIColor.white.cgColor,  // Fully opaque at very top
            UIColor.white.withAlphaComponent(0.95).cgColor,  // Start gentle fade
            UIColor.white.withAlphaComponent(0.85).cgColor,  // Progressive fade
            UIColor.white.withAlphaComponent(0.65).cgColor,  // More transparent
            UIColor.white.withAlphaComponent(0.35).cgColor,  // Significantly faded
            UIColor.white.withAlphaComponent(0.10).cgColor,  // Nearly transparent
            UIColor.clear.cgColor,  // Fully transparent
        ]
        blurFadeOutMask.locations = [0.0, 0.15, 0.35, 0.55, 0.75, 0.9, 1.0]
        blurFadeOutMask.startPoint = CGPoint(x: 0.5, y: 0.0)
        blurFadeOutMask.endPoint = CGPoint(x: 0.5, y: 1.0)
        blurContainerView.layer.mask = blurFadeOutMask

        // Video no longer needs a fade mask since it starts below the blur
        // The blur's fade-out mask handles the smooth transition
        // Removed: videoContainerView.layer.mask = videoGradientMask

        // Gradient overlay for better text readability
        gradientLayer.colors = [
            UIColor.clear.cgColor,
            UIColor.black.withAlphaComponent(0.3).cgColor,
            UIColor.black.withAlphaComponent(0.8).cgColor,
        ]
        gradientLayer.locations = [0.0, 0.6, 1.0]
        videoContainerView.layer.addSublayer(gradientLayer)

        // Live badge with enhanced styling
        liveBadge.translatesAutoresizingMaskIntoConstraints = false
        contentView.addSubview(liveBadge)

        // Viewer count with enhanced styling
        viewerCountLabel.font = .systemFont(ofSize: 14, weight: .semibold)
        viewerCountLabel.textColor = .white
        viewerCountLabel.layer.shadowColor = UIColor.black.cgColor
        viewerCountLabel.layer.shadowOffset = CGSize(width: 0, height: 1)
        viewerCountLabel.layer.shadowRadius = 2
        viewerCountLabel.layer.shadowOpacity = 0.8
        viewerCountLabel.translatesAutoresizingMaskIntoConstraints = false
        contentView.addSubview(viewerCountLabel)

        // Host image with enhanced styling
        hostImageView.contentMode = .scaleAspectFill
        hostImageView.clipsToBounds = true
        hostImageView.backgroundColor = .systemGray5
        hostImageView.layer.cornerRadius = 20
        hostImageView.layer.borderWidth = 2
        hostImageView.layer.borderColor = UIColor.white.cgColor
        hostImageView.layer.shadowColor = UIColor.black.cgColor
        hostImageView.layer.shadowOffset = CGSize(width: 0, height: 2)
        hostImageView.layer.shadowRadius = 4
        hostImageView.layer.shadowOpacity = 0.3
        hostImageView.translatesAutoresizingMaskIntoConstraints = false
